# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MongoDB (user preferences)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/?appName=<app-name>
MONGO_DB_NAME=user-preference-db

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_HOURS=24

# Default admin account (created on first startup if no admin exists)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@moviedb.local
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin
